{
  "name": "spike-pi",
  "version": "1.0.0",
  "description": "SPIKE Pi — Visual Robot Programming",
  "author": "SPIKE Pi",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux",
    "dist:all": "electron-builder --win --linux"
  },
  "build": {
    "appId": "com.spikepi.robot",
    "productName": "SPIKE Pi",
    "files": [
      "electron/**/*",
      "index.html",
      "main.js",
      "styles/**/*",
      "blocks/**/*",
      "blockly/**/*",
      "generators/**/*",
      "serial/**/*",
      "ui/**/*",
      "node_modules/blockly/**/*",
      "node_modules/@fontsource/**/*",
      "node_modules/@serialport/**/*",
      "node_modules/serialport/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Education"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.0.0",
    "@fontsource/nunito": "^5.0.0",
    "blockly": "^10.4.3",
    "serialport": "^12.0.0"
  }
}
